# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored; never commit secrets.

# Required: your Vercel AI Gateway API key (starts with vck_)
AI_GATEWAY_API_KEY=

# Optional: override the gateway endpoint (default below)
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional: which model to route to. Format: <provider>/<model>
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-5
